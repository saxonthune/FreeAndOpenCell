{
  "_placeholder": true,
  "_about": "Canonical state machine for the drag/snap UI interaction. Spec lives in .carta/02-design/03-ui-state.md. Runtime tooling chosen at implementation.",
  "id": "ui-drag",
  "initial": "idle",
  "states": {
    "idle": {
      "on": { "POINTER_DOWN": "pressing" }
    },
    "pressing": {
      "on": {
        "PRESS_PROMOTE":       "dragging",
        "PRESS_RELEASE":       "idle",
        "POINTER_UP_ILLEGAL":  "idle"
      }
    },
    "dragging": {
      "on": {
        "POINTER_MOVE":        "dragging",
        "POINTER_UP_LEGAL":    "snapping",
        "POINTER_UP_ILLEGAL":  "cancelling"
      }
    },
    "snapping":   { "on": { "ANIMATION_END": "idle" } },
    "cancelling": { "on": { "ANIMATION_END": "idle" } }
  }
}
